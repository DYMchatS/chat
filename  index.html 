<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Supabase 实时聊天室</title>
  <!-- 引入 Supabase 的官方 JS 库 -->
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2">
<script>
  // ==========================================
  // ⚠️ 重要：请在这里替换成你自己的 Supabase 信息！
  const SUPABASE_URL = 'https://xdyfxuhllalwihohzffcr.supabase.co
';
  const SUPABASE_ANON_KEY = 'sb_publishable_Yj-KNZPLi4mPgiAduODQ-A_2WDYQxdg';
  // ==========================================

  // 初始化 Supabase 客户端
  const supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

  let currentUser = null;

  // 登录逻辑
  function login() {
    const u = document.getElementById('username').value.trim();
    const err = document.getElementById('loginError');
    err.textContent = '';
    
    if (!u) {
      err.textContent = '请输入昵称';
      return;
    }
    
    currentUser = u;
    document.getElementById('loginPage').style.display = 'none';
    document.getElementById('chatPage').style.display = 'flex';
    document.getElementById('chatTitle').textContent = `聊天室 (${currentUser})`;
    
    // 登录成功后，先加载历史消息，再开启实时监听
    loadMessages();
    subscribeToMessages();
  }

  // 从 Supabase 加载历史消息
  async function loadMessages() {
    const container = document.getElementById('messages');
    container.innerHTML = '<div style="text-align:center;color:#999;">正在加载消息...</div>';

    const { data, error } = await supabase
      .from('messages')
      .select('*')
      .order('created_at', { ascending: true })
      .limit(50); // 只加载最近 50 条历史消息

    if (error) {
      console.error('加载消息失败:', error);
      container.innerHTML = '<div style="text-align:center;color:red;">加载失败，请检查配置</div>';
      return;
    }

    container.innerHTML = '';
    data.forEach(msg => renderMessage(msg.username, msg.content));
    container.scrollTop = container.scrollHeight;
  }

  // 监听 Supabase 的实时新消息
  function subscribeToMessages() {
    supabase
      .channel('realtime-messages')
      .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'messages' }, (payload) => {
        const newMsg = payload.new;
        // 如果是自己发的消息，前端在发送时已经渲染过了，这里就不再重复渲染
        if (newMsg.username !== currentUser) {
          renderMessage(newMsg.username, newMsg.content);
          const container = document.getElementById('messages');
          container.scrollTop = container.scrollHeight;
        }
      })
      .subscribe();
  }

  // 发送消息到 Supabase
  async function sendMsg() {
    const input = document.getElementById('msgInput');
    const text = input.value.trim();
    if (!text || !currentUser) return;

    // 先把消息渲染到自己界面上（提升体验）
    renderMessage(currentUser, text, true);
    input.value = '';
    input.style.height = 'auto';
    const container = document.getElementById('messages');
    container.scrollTop = container.scrollHeight;

    // 存入 Supabase 数据库
    const { error } = await supabase
      .from('messages')
      .insert({ username: currentUser, content: text });

    if (error) {
      console.error('发送失败:', error);
      alert('消息发送失败，请检查网络或 Supabase 配置！');
    }
  }

  // 在页面上渲染单条消息
  function renderMessage(user, text, isMe = false) {
    const container = document.getElementById('messages');
    const div = document.createElement('div');
    // 如果是当前用户发的，强制加上 'me' 样式
    const className = isMe || user === currentUser ? 'me' : 'other';
    div.className = `message ${className}`;
    div.innerHTML = `<span class="message-header">${escapeHtml(user)}</span>${escapeHtml(text)}`;
    container.appendChild(div);
  }

  // 防 XSS 攻击的安全转义函数
  function escapeHtml(text) {
    const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' };
    return text.replace(/[&<>"']/g, m => map[m]);
  }

  // 绑定页面交互事件
  document.getElementById('loginBtn').addEventListener('click', login);
  document.getElementById('sendBtn').addEventListener('click', sendMsg);
  
  // 支持回车键登录和发送消息
  document.getElementById('username').addEventListener('keypress', (e) => { 
    if (e.key === 'Enter') login(); 
  });
  
  document.getElementById('msgInput').addEventListener('keypress', (e) => { 
    if (e.key === 'Enter' && !e.shiftKey) { 
      e.preventDefault(); 
      sendMsg(); 
    } 
  });
  
  // 页面加载完成后自动聚焦输入框
  window.onload = () => {
    document.getElementById('username').focus();
  };
</script>
-- 1. 创建用于存放聊天消息的 messages 表
CREATE TABLE IF NOT EXISTS messages (
  id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY, -- 自动生成唯一ID
  username TEXT NOT NULL,                                 -- 发送消息的用户昵称
  content TEXT NOT NULL,                                  -- 消息内容
  created_at TIMESTAMPTZ DEFAULT NOW()                    -- 消息发送时间（带时区）
);

-- 2. 开启这张表的实时订阅功能（让前端能实时收到新消息）
ALTER PUBLICATION supabase_realtime ADD TABLE messages;

-- 3. 开启行级安全策略 (RLS)
ALTER TABLE messages ENABLE ROW LEVEL SECURITY;

-- 4. 设置权限策略：允许任何人读取和插入消息（适合当前的匿名聊天室场景）
CREATE POLICY "Allow anonymous read and insert" 
ON messages 
FOR ALL 
USING (true) 
WITH CHECK (true);
